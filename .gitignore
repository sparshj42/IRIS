/ab_removal.png
/sam3_masks.png
/occ_slices.png
/result_*.png
/removal_test*.png
/grounding_output.png
/depth_output.png
/depth_ordering.png
/test_mesh.obj
/test.png

# ── Python
__pycache__/
*.pyc
*.egg-info/
.ipynb_checkpoints/

# ── Keep: src/, docs/ (incl. docs/images), scripts/, README, LICENSE,
